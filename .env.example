# Root Environment Configuration Example for ResearchReel
# Duplicate this file to .env at the root or within subfolders as needed

# --- GENERAL SETUP ---
NODE_ENV=development
PORT=5000

# --- DATABASE & CACHE ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_placeholder
POSTGRES_DB=researchreel
DATABASE_URL=postgresql://postgres:postgres_password_placeholder@localhost:5432/researchreel
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# --- JWT AUTHENTICATION ---
JWT_SECRET=PLACEHOLDER_JWT_SECRET_MUST_BE_AT_LEAST_32_CHARS_LONG
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# --- AI & RAG SERVICES ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
QDRANT_URL=YOUR_QDRANT_URL_HERE
QDRANT_API_KEY=YOUR_QDRANT_API_KEY_HERE

# --- THIRD-PARTY APIS ---
ORCID_CLIENT_ID=YOUR_ORCID_CLIENT_ID_HERE
ORCID_CLIENT_SECRET=YOUR_ORCID_CLIENT_SECRET_HERE
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# --- STORAGE ---
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE
AWS_S3_BUCKET=researchreel-media-dev
